# ─────────────────────────────────────────────────────────────
# Stellar network (testnet defaults)
# ─────────────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# ─────────────────────────────────────────────────────────────
# SEP-24 reference anchor
# ─────────────────────────────────────────────────────────────
ANCHOR_HOME_DOMAIN=testanchor.stellar.org
ANCHOR_TEST_ASSET=SRT

# ─────────────────────────────────────────────────────────────
# Contracts (testnet) — fill after deploy
# ─────────────────────────────────────────────────────────────
YIELD_SPLITTER_CONTRACT_ID=
BLEND_POOL_ID=
DEFINDEX_VAULT_ADDRESS=
USDC_TOKEN_ID=CAQCFVLOBK5GIULPNZRGATJJMIZL5BSP7X5YJVMGCPTUEPFM4AVSRCJU

# ─────────────────────────────────────────────────────────────
# SEP-10 signing keypair (NestJS anchor proxy)
# Generate: stellar keys generate --network testnet raiz-anchor
# NUNCA commitear la secret key — solo el public key va aquí
# ─────────────────────────────────────────────────────────────
SEP10_SERVER_KEY_PUBLIC=
SEP10_SERVER_KEY_SECRET=

# ─────────────────────────────────────────────────────────────
# JWT (SEP-10 token signing — NestJS)
# Generate: openssl rand -base64 64
# ─────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ─────────────────────────────────────────────────────────────
# DeFindex
# ─────────────────────────────────────────────────────────────
DEFINDEX_API_KEY=

# ─────────────────────────────────────────────────────────────
# Blend Protocol (lectura de APY — server-side)
# Pool ID de testnet: https://testnet.blend.capital
# ─────────────────────────────────────────────────────────────
BLEND_API_URL=https://blend-utils.stellar.org/api

# ─────────────────────────────────────────────────────────────
# Supabase Postgres (server-side)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# API <-> web
# ─────────────────────────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Frontend (Next.js — solo vars NEXT_PUBLIC_* llegan al browser)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_YIELD_SPLITTER_CONTRACT_ID=
NEXT_PUBLIC_DEFINDEX_VAULT_ADDRESS=
NEXT_PUBLIC_USDC_TOKEN_ID=CAQCFVLOBK5GIULPNZRGATJJMIZL5BSP7X5YJVMGCPTUEPFM4AVSRCJU
